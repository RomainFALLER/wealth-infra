# Terraform state & cache
.terraform/
# Note: .terraform.lock.hcl is intentionally NOT ignored — commit it to pin provider versions
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
tfplan
plan_output.txt
crash.log
crash.*.log

# Variable files with secrets — never commit these
*.auto.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local env / secrets
.env
.envrc
secrets.*.env
